# Default: ignore everything
*

# Keep this file and repo metadata essentials
!.gitignore
!.gitattributes
!*.uproject

# Keep C++ source headers/implementation under Source
!Source/
!Source/**/
!Source/**/*.h
!Source/**/*.hpp
!Source/**/*.inl
!Source/**/*.cpp
!Source/**/*.c

# Keep Unreal build scripts under Source
!Source/**/*.Build.cs
!Source/**/*.Target.cs

# Optional: keep plugin C++ source too
!Plugins/**/Source/
!Plugins/**/Source/**/
!Plugins/**/Source/**/*.h
!Plugins/**/Source/**/*.hpp
!Plugins/**/Source/**/*.inl
!Plugins/**/Source/**/*.cpp
!Plugins/**/Source/**/*.c
!Plugins/**/Source/**/*.Build.cs
!Plugins/**/Source/**/*.Target.cs
